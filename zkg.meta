[package]
description = Official Zeek package for JA4+ network fingerprinting.
tags = ja4, fingerprint, fingerprinting, ja4s, ja4h, ja4x, ja4ssh, ja4l, ja4t, ja4+, ja4plus, ja3, ja4d, ja4d6
script_dir = ja4-plugin/scripts
build_command = cd ja4-plugin && ./configure && cd build && make
version = 2.0
credits = John Althouse
depends = zeek >=5.0.0
